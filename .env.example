# 数据库配置
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password
DATABASE_NAME=AuthForge_auth

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-here-min-256-bits
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# 应用配置
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# 邮件服务配置 (Gmail/SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=AuthForge <your-email@gmail.com>

# 短信服务配置 (阿里云SMS)
SMS_ACCESS_KEY_ID=your-access-key-id
SMS_ACCESS_KEY_SECRET=your-access-key-secret
SMS_SIGN_NAME=your-sms-sign
SMS_TEMPLATE_CODE=SMS_123456789

# OAuth 配置
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# 客户端回调URL
CLIENT_URL=http://localhost:3001

# 安全配置
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=900000
PASSWORD_SALT_ROUNDS=12

# MFA 配置
MFA_ISSUER=AuthForge
MFA_SERVICE_NAME=AuthForge Auth