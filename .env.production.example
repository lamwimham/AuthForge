# 生产环境配置
# 复制此文件为 .env.production 并填入实际值

# 数据库密码
POSTGRES_PASSWORD=your_secure_postgres_password_here

# Redis 密码
REDIS_PASSWORD=your_secure_redis_password_here

# JWT 密钥（必须是强随机字符串，至少32字符）
JWT_SECRET=your_super_secure_jwt_secret_key_at_least_32_characters_long

# 邮件服务配置
MAIL_HOST=smtp.yourdomain.com
MAIL_PORT=587
MAIL_USER=noreply@yourdomain.com
MAIL_PASSWORD=your_mail_password
MAIL_FROM=SpellBackend <noreply@yourdomain.com>

# OAuth 配置（如果需要）
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# 客户端回调URL
CLIENT_URL=https://yourdomain.com

# 短信服务配置（如果需要）
SMS_ACCESS_KEY_ID=your_sms_access_key_id
SMS_ACCESS_KEY_SECRET=your_sms_access_key_secret
SMS_SIGN_NAME=your_app_name
SMS_TEMPLATE_CODE=SMS_123456789

# MFA 配置
MFA_ISSUER=YourAppName
MFA_SERVICE_NAME=YourAppName Auth